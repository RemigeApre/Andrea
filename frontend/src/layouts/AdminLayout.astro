---
import '../styles/fonts.css';
import '../styles/admin.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  activePage?: string;
}

const { title, activePage = '' } = Astro.props;
const directusUrl = process.env.DIRECTUS_URL || 'http://localhost:8056';

const navItems = [
  { href: '/admin/notes', label: 'Notes rapides', key: 'notes', icon: 'edit_note' },
  { href: '/admin/articles', label: 'Articles', key: 'articles', icon: 'article' },
  { href: '/admin/messages', label: 'Messages', key: 'messages', icon: 'mail' },
  { href: '/admin/gestion', label: 'Gestion', key: 'gestion', icon: 'tune' },
  { href: '/admin/administration', label: 'Administration', key: 'administration', icon: 'settings' },
];
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="directus-url" content={directusUrl}>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/favicon-admin.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">
  <title>{title}</title>
  <ViewTransitions />
</head>
<body class="adm">

  <header class="adm-header">
    <div class="adm-header-inner">
      <a href="/" class="adm-back">
        <span class="material-symbols-rounded">arrow_back</span>
        <span>Retour au site</span>
      </a>
      <nav class="adm-nav">
        {navItems.map(item => (
          <a href={item.href} class={`adm-nav-item ${activePage === item.key ? 'active' : ''}`}>
            <span class="material-symbols-rounded adm-nav-icon">{item.icon}</span>
            <span class="adm-nav-label">{item.label}</span>
          </a>
        ))}
      </nav>
      <div class="adm-right">
        <form method="POST" action="/deconnexion">
          <button type="submit" class="adm-logout" title="Déconnexion">
            <span class="material-symbols-rounded">logout</span>
          </button>
        </form>
      </div>
    </div>
  </header>

  <main class="adm-main">
    <slot />
  </main>

  <!-- Bulle paramètres -->
  <div class="settings-bubble" id="settingsBubble">
    <button class="settings-toggle" id="settingsToggle" title="Paramètres">
      <span class="material-symbols-rounded">settings</span>
    </button>
    <div class="settings-panel" id="settingsPanel" hidden>
      <div class="settings-row">
        <span>Mode sombre</span>
        <label class="settings-switch"><input type="checkbox" id="setDark" /><span></span></label>
      </div>
      <div class="settings-row">
        <span>Masquer les infos</span>
        <label class="settings-switch"><input type="checkbox" id="setHideHints" /><span></span></label>
      </div>
      <div class="settings-row">
        <span>Masquer les encarts</span>
        <label class="settings-switch"><input type="checkbox" id="setHideAdvice" /><span></span></label>
      </div>
    </div>
  </div>

  <script>
    function initAdmin() {
      // Log connexion
      if (window.location.search.includes('logged=1')) {
        const logs = JSON.parse(localStorage.getItem('andrea_logs') || '[]');
        const entry: any = { type: 'login', date: new Date().toISOString(), ua: navigator.userAgent };
        fetch('https://api.ipify.org?format=json').then(r => r.json()).then(d => {
          entry.ip = d.ip; logs.unshift(entry); localStorage.setItem('andrea_logs', JSON.stringify(logs.slice(0, 500)));
        }).catch(() => { logs.unshift(entry); localStorage.setItem('andrea_logs', JSON.stringify(logs.slice(0, 500))); });
        history.replaceState(null, '', window.location.pathname);
      }

      const body = document.body;
      const setDark = document.getElementById('setDark') as HTMLInputElement;
      const setHideHints = document.getElementById('setHideHints') as HTMLInputElement;
      const setHideAdvice = document.getElementById('setHideAdvice') as HTMLInputElement;
      const settingsPanel = document.getElementById('settingsPanel')!;
      const settingsToggle = document.getElementById('settingsToggle')!;

      // Init state
      if (localStorage.getItem('adm_dark') === '1') { body.classList.add('dark'); setDark.checked = true; }
      if (localStorage.getItem('adm_hide_hints') === '1') { body.classList.add('hide-hints'); setHideHints.checked = true; }
      if (localStorage.getItem('adm_hide_advice') === '1') { body.classList.add('hide-advice'); setHideAdvice.checked = true; }

      settingsToggle.addEventListener('click', () => { settingsPanel.hidden = !settingsPanel.hidden; });
      document.addEventListener('click', (e) => { if (!(e.target as Element).closest('.settings-bubble')) settingsPanel.hidden = true; });

      setDark.addEventListener('change', () => {
        body.classList.toggle('dark', setDark.checked);
        localStorage.setItem('adm_dark', setDark.checked ? '1' : '0');
      });

      setHideHints.addEventListener('change', () => {
        body.classList.toggle('hide-hints', setHideHints.checked);
        localStorage.setItem('adm_hide_hints', setHideHints.checked ? '1' : '0');
      });

      setHideAdvice.addEventListener('change', () => {
        body.classList.toggle('hide-advice', setHideAdvice.checked);
        localStorage.setItem('adm_hide_advice', setHideAdvice.checked ? '1' : '0');
      });
    }
    initAdmin();
    document.addEventListener('astro:after-swap', initAdmin);
  </script>

</body>
</html>
