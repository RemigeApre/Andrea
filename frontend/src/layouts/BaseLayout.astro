---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { fetchSingleton } from '../lib/directus';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  activePage?: string;
  adminTheme?: boolean;
}

const { title, description = '', activePage = '', adminTheme = false } = Astro.props;

let siteInfo: any = null;
try {
  siteInfo = await fetchSingleton('site_info');
} catch {
  // Fallback if Directus is down
  siteInfo = {
    name: 'Andrea Simonet-Davin',
    title: 'Psychologue à Canet-en-Roussillon',
    phone: '06 69 35 09 12',
    email: 'simonet.davin@gmail.com',
    address: '168 Av. Edouard Herriot, 66140 Canet-en-Roussillon',
    adeli: '10111639034',
    doctolib_url: 'https://www.doctolib.fr/psychologue/canet-en-roussillon/andrea-simonet-davin'
  };
}
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:locale" content="fr_FR">
  <link rel="canonical" href={Astro.url.href}>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Psychologist",
    "name": siteInfo.name,
    "jobTitle": "Psychologue",
    "telephone": siteInfo.phone,
    "email": siteInfo.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "168 Avenue Edouard Herriot",
      "addressLocality": "Canet-en-Roussillon",
      "postalCode": "66140",
      "addressCountry": "FR"
    },
    "url": Astro.site ?? Astro.url.origin,
    "knowsLanguage": ["fr", "en", "pt"]
  })} />
  <link rel="preconnect" href="https://api.fontshare.com">
  <link href="https://api.fontshare.com/v2/css?f[]=author@300,400,500,600&f[]=gambarino@400&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">
  <title>{title}</title>
  <ViewTransitions />
</head>
<body class={adminTheme ? 'theme-admin' : ''}>
  <Header activePage={activePage} siteInfo={siteInfo} />
  <main>
    <slot />
  </main>
  <Footer siteInfo={siteInfo} />

  <a
    href="https://www.qare.fr/praticien/69f3b164efcfc1003f9aa1f8?all=true&selectedSpeciality=psychologist&standardizedMotives="
    class="floating-rdv"
    target="_blank"
    rel="noopener"
    aria-label="Prendre rendez-vous"
  >
    <span class="material-symbols-rounded">calendar_month</span>
    <span class="floating-rdv-label">Prendre rendez-vous</span>
  </a>

  <script>
    document.querySelector('.menu-toggle')?.addEventListener('click', () => {
      document.querySelector('.nav-links')?.classList.toggle('open');
    });
  </script>

  <style>
    .floating-rdv {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      z-index: 100;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--primary);
      color: #fff;
      text-decoration: none;
      padding: 0.75rem 1.25rem;
      border-radius: 999px;
      font-family: 'Author', serif;
      font-size: 0.9rem;
      font-weight: 600;
      box-shadow: 0 4px 20px rgba(28, 63, 110, 0.35);
      transition: background 0.2s ease;
    }

    .floating-rdv:hover {
      background: #152e52;
    }

    .floating-rdv .material-symbols-rounded {
      font-size: 1.1rem;
    }

    @media (max-width: 480px) {
      .floating-rdv-label {
        display: none;
      }
      .floating-rdv {
        padding: 0.85rem;
      }
      .floating-rdv .material-symbols-rounded {
        font-size: 1.3rem;
      }
    }
  </style>
</body>
</html>
