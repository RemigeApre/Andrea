---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';

const DIRECTUS_URL = process.env.DIRECTUS_URL || 'http://localhost:8056';
const { slug } = Astro.params;

let article: any = null;

try {
  // Essayer par slug d'abord
  let res = await fetch(`${DIRECTUS_URL}/items/articles?filter[slug][_eq]=${encodeURIComponent(slug!)}&filter[status][_eq]=published&limit=1`);
  if (res.ok) {
    const data = (await res.json()).data;
    if (data?.length) article = data[0];
  }
  // Sinon par ID
  if (!article) {
    res = await fetch(`${DIRECTUS_URL}/items/articles/${slug}`);
    if (res.ok) article = (await res.json()).data;
  }
} catch {}

if (!article) return Astro.redirect('/404');

const date = article.date_published ? new Date(article.date_published).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
---

<BaseLayout
  title={article.title}
  description={article.excerpt || ''}
  activePage="articles"
>

  <article class="article-page">
    <div class="container">
      <div class="article-header">
        <a href="/articles" class="article-back">
          <span class="material-symbols-rounded">arrow_back</span>
          Articles
        </a>
        <div class="article-meta">
          {article.tags && (
            <div class="article-tags-row">
              {article.tags.split(',').map((t: string) => t.trim()).filter(Boolean).map((t: string) => (
                <a href={`/articles?tag=${encodeURIComponent(t)}`} class="article-tag">{t}</a>
              ))}
            </div>
          )}
          {date && <span class="article-date">{date}</span>}
        </div>
        <h1>{article.title}</h1>
      </div>
      <div class="article-body" set:html={article.body} />
      <div class="article-footer">
        <a href="/articles" class="article-back-bottom">
          <span class="material-symbols-rounded">arrow_back</span>
          Tous les articles
        </a>
      </div>
    </div>
  </article>

</BaseLayout>

<style>
  .article-page {
    padding: 2rem 0 4rem;
  }

  .article-page .container {
    max-width: 720px;
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-back {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: 'Author', serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--primary);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: opacity 0.2s;
  }

  .article-back:hover { opacity: 0.65; }
  .article-back .material-symbols-rounded { font-size: 0.95rem; }

  .article-tags-row { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .article-tag { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: white; font-family: 'Author', serif; font-weight: 700; background: var(--primary); padding: 0.2rem 0.5rem; border-radius: 3px; text-decoration: none; transition: opacity 0.15s; }
  .article-tag:hover { opacity: 0.8; }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .article-cat {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: white;
    font-family: 'Author', serif;
    font-weight: 700;
    background: var(--primary);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
  }

  .article-date {
    font-size: 0.78rem;
    color: var(--charcoal-light);
    font-family: 'Author', serif;
  }

  h1 {
    font-family: 'Author', serif;
    font-size: 2.2rem;
    font-weight: 600;
    color: var(--charcoal);
    line-height: 1.25;
    margin: 0;
  }

  .article-body {
    font-size: 1rem;
    line-height: 1.85;
    color: var(--charcoal);
    text-align: justify;
    hyphens: auto;
  }

  .article-body :global(h2) {
    font-family: 'Author', serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--primary);
    margin: 2.5rem 0 1rem;
  }

  .article-body :global(h3) {
    font-family: 'Author', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--charcoal);
    margin: 2rem 0 0.75rem;
  }

  .article-body :global(p) {
    margin: 0 0 1.25rem;
  }

  .article-body :global(ul), .article-body :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--primary);
    background: rgba(28, 63, 110, 0.04);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 0 6px 6px 0;
    font-style: italic;
    color: var(--charcoal-light);
  }

  .article-body :global(a) {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-body :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .article-body :global(strong) {
    font-weight: 600;
    color: var(--charcoal);
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .article-back-bottom {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: 'Author', serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--primary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .article-back-bottom:hover { opacity: 0.65; }
  .article-back-bottom .material-symbols-rounded { font-size: 0.95rem; }

  @media (max-width: 640px) {
    h1 { font-size: 1.6rem; }
    .article-body { text-align: left; hyphens: none; }
  }
</style>
