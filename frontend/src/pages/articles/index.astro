---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchItems } from '../../lib/directus';

try { await fetch(new URL('/api/publish-scheduled', Astro.url.origin)); } catch {}

let articles: any[] = [];

try {
  articles = await fetchItems('articles', { sort: '-date_published', 'filter[status][_eq]': 'published' });
} catch {}

// Collecter les tags
const tagSet = new Set<string>();
articles.forEach(a => { if (a.tags) a.tags.split(',').forEach((t: string) => { const s = t.trim(); if (s) tagSet.add(s); }); });
const allTags = [...tagSet].sort();

const activeTag = Astro.url.searchParams.get('tag') || '';
const searchQuery = Astro.url.searchParams.get('q') || '';

let filtered = articles;
if (activeTag) filtered = filtered.filter(a => a.tags && a.tags.split(',').map((t: string) => t.trim()).includes(activeTag));
if (searchQuery) {
  const q = searchQuery.toLowerCase();
  filtered = filtered.filter(a => a.title.toLowerCase().includes(q) || (a.excerpt || '').toLowerCase().includes(q) || (a.tags || '').toLowerCase().includes(q));
}
---

<BaseLayout
  title="Articles"
  description="Articles et réflexions d'Andrea Simonet-Davin, psychologue. Stress, anxiété, bien-être, accompagnement psychologique."
  activePage="articles"
>

  <section class="section">
    <div class="container">

      <!-- Recherche + tags -->
      {articles.length > 0 && (
        <div class="articles-filters">
          <form class="articles-search" method="GET" action="/articles">
            {activeTag && <input type="hidden" name="tag" value={activeTag} />}
            <span class="material-symbols-rounded">search</span>
            <input type="text" name="q" value={searchQuery} placeholder="Rechercher un article..." />
          </form>
          {allTags.length > 0 && (
            <div class="articles-tags">
              <a href="/articles" class={`atag ${!activeTag ? 'active' : ''}`}>Tous</a>
              {allTags.map(t => (
                <a href={`/articles?tag=${encodeURIComponent(t)}${searchQuery ? '&q=' + encodeURIComponent(searchQuery) : ''}`} class={`atag ${activeTag === t ? 'active' : ''}`}>{t}</a>
              ))}
            </div>
          )}
        </div>
      )}

      {filtered.length > 0 ? (
        <div class="articles-grid">
          {filtered.map((a: any) => {
            const date = a.date_published ? new Date(a.date_published).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
            const slug = a.slug || a.id;
            const tags = a.tags ? a.tags.split(',').map((t: string) => t.trim()).filter(Boolean) : [];
            return (
              <a href={`/articles/${slug}`} class="article-card">
                <div class="article-card-top">
                  <div class="article-tags-row">
                    {tags.map((t: string) => <span class="article-tag">{t}</span>)}
                  </div>
                  {date && <span class="article-date">{date}</span>}
                </div>
                <h2 class="article-title">{a.title}</h2>
                {a.excerpt && <p class="article-excerpt">{a.excerpt}</p>}
                <span class="article-read">Lire <span class="material-symbols-rounded">arrow_forward</span></span>
              </a>
            );
          })}
        </div>
      ) : articles.length > 0 ? (
        <div class="articles-empty">
          <p>Aucun article trouvé.</p>
          <a href="/articles" class="articles-reset">Voir tous les articles</a>
        </div>
      ) : (
        <div class="articles-empty">
          <span class="material-symbols-rounded">article</span>
          <p>Les articles arrivent bientôt.</p>
        </div>
      )}
    </div>
  </section>

</BaseLayout>

<style>
  /* Filters */
  .articles-filters { max-width: 900px; margin: 0 auto 2rem; display: flex; flex-direction: column; gap: 0.75rem; }
  .articles-search { display: flex; align-items: center; gap: 0.5rem; background: var(--white); border: 1px solid var(--border); border-radius: 8px; padding: 0.55rem 0.85rem; }
  .articles-search .material-symbols-rounded { font-size: 1.15rem; color: var(--charcoal-light); }
  .articles-search input { border: none; background: none; outline: none; font-family: 'Gambarino', Georgia, serif; font-size: 0.92rem; color: var(--charcoal); width: 100%; }
  .articles-search input::placeholder { color: var(--charcoal-light); }
  .articles-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .atag { font-family: 'Author', serif; font-size: 0.72rem; font-weight: 600; text-decoration: none; padding: 0.3rem 0.7rem; border-radius: 999px; border: 1px solid var(--border); color: var(--charcoal-light); transition: all 0.15s; }
  .atag:hover { border-color: var(--primary); color: var(--primary); }
  .atag.active { background: var(--primary); color: white; border-color: var(--primary); }

  /* Grid */
  .articles-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; max-width: 900px; margin-inline: auto; }
  @media (max-width: 640px) { .articles-grid { grid-template-columns: 1fr; } }

  .article-card { background: var(--white); border: 1px solid var(--border); border-radius: 10px; padding: 1.5rem; text-decoration: none; display: flex; flex-direction: column; gap: 0.6rem; transition: border-color 0.2s, box-shadow 0.2s; }
  .article-card:hover { border-color: var(--primary); box-shadow: 0 4px 20px rgba(28, 63, 110, 0.08); }

  .article-card-top { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
  .article-tags-row { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .article-tag { font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.1em; color: white; font-family: 'Author', serif; font-weight: 700; background: var(--primary); padding: 0.15rem 0.45rem; border-radius: 3px; }
  .article-date { font-size: 0.72rem; color: var(--charcoal-light); font-family: 'Author', serif; flex-shrink: 0; }

  .article-title { font-family: 'Author', serif; font-size: 1.1rem; font-weight: 600; color: var(--charcoal); line-height: 1.35; margin: 0; }
  .article-excerpt { font-size: 0.85rem; color: var(--charcoal-light); line-height: 1.6; margin: 0; text-align: justify; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

  .article-read { display: inline-flex; align-items: center; gap: 0.3rem; font-family: 'Author', serif; font-size: 0.8rem; font-weight: 600; color: var(--primary); margin-top: auto; }
  .article-read .material-symbols-rounded { font-size: 0.9rem; }

  .articles-empty { text-align: center; padding: 4rem 1rem; color: var(--charcoal-light); }
  .articles-empty .material-symbols-rounded { font-size: 3rem; display: block; margin-bottom: 1rem; opacity: 0.2; font-variation-settings: 'FILL' 0, 'wght' 300; }
  .articles-empty p { font-size: 1rem; color: var(--charcoal); }
  .articles-reset { display: inline-block; margin-top: 0.75rem; font-family: 'Author', serif; font-size: 0.85rem; font-weight: 600; color: var(--primary); text-decoration: none; border-bottom: 1px solid currentColor; }
</style>
